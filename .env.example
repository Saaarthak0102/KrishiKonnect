# ============================================================================
# KrishiKonnect Environment Variables - Template
# 
# IMPORTANT NOTES:
# 1. Copy this file to .env.local and fill in your actual API keys
# 2. Never commit .env.local to git (it's in .gitignore)
# 3. Firebase credentials are SAFE to be public (they're for the web app)
# 4. GEMINI_API_KEY should NEVER be exposed to the client
# 5. All NEXT_PUBLIC_* keys are visible in the browser - safe keys only!
# ============================================================================

# ============================================================================
# FIREBASE CONFIGURATION (Required)
# ============================================================================
# Get these from Firebase Console: https://console.firebase.google.com/
# These are safe to be public (they're designed for web apps)

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_id_here:web:your_web_app_id_here

# ============================================================================
# PUBLIC APIs (Optional - add your keys to enable features)
# ============================================================================

# Weather API - for weather data integration (e.g., OpenWeatherMap)
# Get key from: https://openweathermap.org/api
NEXT_PUBLIC_WEATHER_API_KEY=your_weather_api_key_here

# ============================================================================
# SERVER-SIDE ONLY APIs (Do not prefix with NEXT_PUBLIC_)
# ============================================================================
# IMPORTANT: These should NEVER be prefixed with NEXT_PUBLIC_
# These are intentionally NOT included in the browser bundle
# Missing these keys will cause graceful fallbacks, not errors

# Google Gemini AI API - for AI advisor features (server-side only)
# Get key from: https://makersuite.google.com/
# This key is only used on the server and never exposed to the client
GEMINI_API_KEY=your_server_gemini_api_key_here
