rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Community Questions Collection
    match /community_questions/{questionId} {
      // Allow anyone to read questions
      allow read: if true;
      
      // Only authenticated users can write (create/update/delete)
      allow create: if request.auth != null 
                    && request.auth.uid == request.resource.data.userId;
      
      // Users can only update their own questions
      allow update: if request.auth != null 
                    && (request.auth.uid == resource.data.userId 
                        || onlyUpdatingUpvoteOrReplyCount());
      
      // Users can only delete their own questions
      allow delete: if request.auth != null 
                    && request.auth.uid == resource.data.userId;
      
      // Replies Subcollection
      match /replies/{replyId} {
        // Allow anyone to read replies
        allow read: if true;
        
        // Only authenticated users can create replies
        allow create: if request.auth != null 
                      && request.auth.uid == request.resource.data.userId;
        
        // Users can only update their own replies or upvote count
        allow update: if request.auth != null 
                      && (request.auth.uid == resource.data.userId 
                          || onlyUpdatingUpvotes());
        
        // Users can only delete their own replies
        allow delete: if request.auth != null 
                      && request.auth.uid == resource.data.userId;
      }
    }
    
    // Helper function to check if only upvotes are being updated
    function onlyUpdatingUpvotes() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['upvotes']);
    }
    
    // Helper function to check if only upvotes or reply count are being updated
    function onlyUpdatingUpvoteOrReplyCount() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['upvotes']) 
             || affectedKeys.hasOnly(['repliesCount'])
             || affectedKeys.hasOnly(['upvotes', 'repliesCount']);
    }
  }
}
