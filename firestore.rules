rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isQuestionVoteToggle() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let previousUpvotedBy = resource.data.upvotedBy is list ? resource.data.upvotedBy : [];
      let nextUpvotedBy = request.resource.data.upvotedBy is list ? request.resource.data.upvotedBy : [];
      let isUpvote =
        request.resource.data.upvotes == resource.data.upvotes + 1 &&
        nextUpvotedBy.size() == previousUpvotedBy.size() + 1 &&
        nextUpvotedBy.hasAll(previousUpvotedBy) &&
        nextUpvotedBy.hasAny([request.auth.uid]);
      let isRemoveUpvote =
        request.resource.data.upvotes == resource.data.upvotes - 1 &&
        nextUpvotedBy.size() == previousUpvotedBy.size() - 1 &&
        previousUpvotedBy.hasAll(nextUpvotedBy) &&
        previousUpvotedBy.hasAny([request.auth.uid]);

      return changed.hasOnly(['upvotes', 'upvotedBy']) &&
        request.resource.data.upvotes is int &&
        request.resource.data.upvotes >= 0 &&
        request.resource.data.upvotedBy is list &&
        (isUpvote || isRemoveUpvote);
    }

    function isReplyVoteToggle() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let previousUpvotedBy = resource.data.upvotedBy is list ? resource.data.upvotedBy : [];
      let nextUpvotedBy = request.resource.data.upvotedBy is list ? request.resource.data.upvotedBy : [];
      let isUpvote =
        request.resource.data.upvotes == resource.data.upvotes + 1 &&
        nextUpvotedBy.size() == previousUpvotedBy.size() + 1 &&
        nextUpvotedBy.hasAll(previousUpvotedBy) &&
        nextUpvotedBy.hasAny([request.auth.uid]);
      let isRemoveUpvote =
        request.resource.data.upvotes == resource.data.upvotes - 1 &&
        nextUpvotedBy.size() == previousUpvotedBy.size() - 1 &&
        previousUpvotedBy.hasAll(nextUpvotedBy) &&
        previousUpvotedBy.hasAny([request.auth.uid]);

      return changed.hasOnly(['upvotes', 'upvotedBy']) &&
        request.resource.data.upvotes is int &&
        request.resource.data.upvotes >= 0 &&
        request.resource.data.upvotedBy is list &&
        (isUpvote || isRemoveUpvote);
    }

    // Users Collection - Store farmer profiles and starred crops
    match /users/{userId} {
      // Only authenticated users can read their own profile
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Only authenticated users can write their own profile
      allow write: if isSignedIn() && request.auth.uid == userId;

      // Transport Bookings Subcollection
      match /transportBookings/{bookingId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Community Questions Collection
    match /community_questions/{questionId} {
      // Anyone can read questions (public feed)
      allow read: if true;

      // Only authenticated users can create questions
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      // Question owner can update all fields. Any signed-in user can only toggle vote fields.
      allow update: if isSignedIn() && (
                      resource.data.userId == request.auth.uid ||
                      isQuestionVoteToggle()
                    );

      // Only the question owner can delete their question
      allow delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;

      // Replies Subcollection
      match /replies/{replyId} {
        // Anyone can read replies
        allow read: if true;

        // Only authenticated users can create replies
        allow create: if isSignedIn()
                      && request.resource.data.userId == request.auth.uid;

        // Reply owner can update all fields. Any signed-in user can only toggle vote fields.
        allow update: if isSignedIn() && (
                        resource.data.userId == request.auth.uid ||
                        isReplyVoteToggle()
                      );

        // Only the reply owner can delete their reply
        allow delete: if isSignedIn()
                      && resource.data.userId == request.auth.uid;
      }
    }

    // Community Feed Cache - Optimized read performance
    match /community_feed/latest_questions {
      // Anyone can read the feed cache
      allow read: if true;

      // Only authenticated users can write (via Cloud Functions or client-side updates)
      allow write: if isSignedIn();
    }
  }
}
